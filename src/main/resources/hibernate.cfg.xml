<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- Microsoft SQL Server (database "turingdb", topic OnlineShopOrders) -->
        <property name="hibernate.connection.driver_class">
            com.microsoft.sqlserver.jdbc.SQLServerDriver
        </property>
        <property name="hibernate.connection.url">
            jdbc:sqlserver://185.119.119.126:1433;databaseName=turingdb;encrypt=true;trustServerCertificate=true
        </property>
        <property name="hibernate.connection.username">turing</property>
        <property name="hibernate.connection.password">turing</property>

        <!-- The SQL Server dialect is auto-detected from the JDBC connection. -->

        <!-- The table already exists and is read-only: never let Hibernate touch the schema. -->
        <property name="hibernate.hbm2ddl.auto">none</property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Entity mapping -->
        <mapping class="org.example.entity.Order"/>

    </session-factory>
</hibernate-configuration>
